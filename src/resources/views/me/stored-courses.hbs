<form class="container mt-4" name="container-form" method="POST" action="/courses/handle-form-actions">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="mb-4">Khoá học của tôi</h2>

            <div class="d-flex align-items-center">
                <div class="form-check mr-2">
                    <input class="form-check-input" type="checkbox" value="" id="checkbox-all">
                    <label class="form-check-label" for="checkbox-all">
                        Chọn tất cả
                    </label>
                </div>

                <div class="d-flex">
                    <select class="form-control form-control-sm flex-fill mr-2" name="action" required>
                        <option value="">-- Chọn hành động --</option>
                        <option value="delete-all">-- Xoá --</option>
                    </select>

                    <button type="button" class="btn btn-primary btn-sm btn-apdung" disabled>
                        Áp dụng
                    </button>
                </div>
            </div>
        </div>

        <div>
            <a href="/me/trash/courses" class="btn btn-primary">
                Đi đến Thùng rác ({{deletedCount}})
            </a>
            <a href="/courses/create" class="btn btn-success">
                + Thêm khóa học
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">

        <table class="table table-hover align-middle">

            <thead class="thead-dark">
                <tr>
                    <th></th>
                    <th>#</th>
                    <th>Hình ảnh</th>
                    {{!-- <th>Tên khóa học</th> --}}
                    <th class="d-flex align-items-center">
                        <span class="mr-1">Tên khóa học</span>
                        <a href="?_sort&column=name&type=asc">↓</a>
                        <a href="?_sort&column=name&type=desc">↑</a>
                    </th>
                    <th>Trình độ</th>
                    <th>Ngày tạo</th>
                    <th>Ngày cập nhật</th>
                    <th colspan="2">Hành động</th>
                </tr>
            </thead>

            <tbody>

                {{#each courses}}
                <tr>
                    <td>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="{{this._id}}" name="checkboxItem[]">
                        </div>
                    </td>

                    <td>{{sum @index 1}}</td>

                    <td>
                        <a href="/courses/{{this.slug}}" class="">
                            <img src="{{this.thumbnail}}" class="table-img" alt="{{this.name}}">
                        </a>
                        {{!-- <img src="{{this.thumbnail}}" class="table-img"> --}}
                    </td>

                    <td>{{this.name}}</td>

                    <td>{{this.level}}</td>

                    <td>{{formatDate this.createdAt}}</td>

                    <td>{{formatDate this.updatedAt}}</td>

                    <td>
                        <a href="/courses/{{this._id}}/edit" class="btn btn-warning btn-sm">
                            Sửa
                        </a>
                    </td>

                    <td>
                        <button href="#" class="btn btn-danger btn-sm" data-id="{{this._id}}" data-name="{{this.name}}"
                            data-toggle="modal" data-target="#exampleModal">
                            Xoá
                        </button>
                    </td>

                </tr>

                {{else}}
                <tr>
                    <td colspan="8" class="text-center">
                        Bạn chưa đăng khoá học nào.
                        {{!-- <a href="/courses/create">Thêm khoá học!</a> --}}
                        <a href="/courses/create" class="">
                            + Thêm khóa học
                        </a>
                    </td>
                </tr>


                {{/each}}

            </tbody>

        </table>

    </div>

    <!-- Modal -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Xoá khoá học</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div>Bạn chắc chắn muốn xoá khoá học này?</div>
                    <div><strong id="course-name"></strong>?</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Huỷ</button>
                    <button id="btn-delete" type="button" class="btn btn-danger">Xoá bỏ</button>
                </div>
            </div>
        </div>
    </div>


</form>

{{!-- hidden form delete --}}
<form method="POST" name="form-delete"></form>



<script>
    document.addEventListener('DOMContentLoaded', function () {
        let id
        let name
        const btnDelete = document.getElementById('btn-delete')
        const formDelete = document.forms['form-delete']
        const containerForm = document.forms['container-form']
        const courseName = document.getElementById('course-name')
        const checkboxAll = $('#checkbox-all')
        const checkboxItem = $('input[name="checkboxItem[]"]')
        const btnApDung = $('.btn-apdung')

        $('#exampleModal').on('show.bs.modal', function (event) {
            const button = $(event.relatedTarget)

            id = button.data('id')
            name = button.data('name')

            courseName.textContent = name
        })

        btnDelete.addEventListener('click', function () {
            formDelete.action = '/courses/' + id + '?_method=DELETE'
            formDelete.submit()
        })

        checkboxAll.change(function () {
            const isCheckedAll = $(this).prop('checked')
            checkboxItem.prop('checked', isCheckedAll)
            clearDisabled()
        })

        checkboxItem.change(function () {
            const isCheckedAll = checkboxItem.length === $('input[name="checkboxItem[]"]:checked').length
            checkboxAll.prop('checked', isCheckedAll)
            clearDisabled()
        })

        // form ap dung
        btnApDung.click(function (e) {
            e.preventDefault()

            const hasChecked = $('input[name="checkboxItem[]"]:checked').length > 0
            const action = $('select[name="action"]').val()

            if (!hasChecked || !action) {
                return
            }

            containerForm.submit()
        })

        function clearDisabled() {
            const checkedCount = $('input[name="checkboxItem[]"]:checked').length

            if (checkedCount > 0) {
                btnApDung.prop('disabled', false)
            } else {
                btnApDung.prop('disabled', true)
            }
        }
    })
</script>


